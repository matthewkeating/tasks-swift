{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "swift build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": ["$swiftc"]
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "swift build -c release",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": ["$swiftc"]
        },
        {
            "label": "Bundle Debug App",
            "type": "shell",
            "command": "swift build && ./scripts/make-app.sh debug",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": ["$swiftc"]
        },
        {
            "label": "Bundle Release App",
            "type": "shell",
            "command": "swift build -c release && ./scripts/make-app.sh release",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": ["$swiftc"]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "swift package clean",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
