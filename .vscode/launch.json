{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "swift",
            "request": "launch",
            "name": "Debug Tasks",
            // Launch the binary from inside the assembled .app bundle so that
            // Bundle.main reads Contents/Info.plist (GIDClientID, bundle id) and
            // the OAuth redirect URL scheme is registered — matching production.
            "program": "${workspaceFolder}/.build/debug/Tasks.app/Contents/MacOS/Tasks",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Bundle Debug App"
        },
        {
            "type": "swift",
            "request": "launch",
            "name": "Debug Tasks (Mock Data)",
            "program": "${workspaceFolder}/.build/debug/Tasks.app/Contents/MacOS/Tasks",
            "args": [
                "-mock"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Bundle Debug App"
        },
        {
            "type": "swift",
            "request": "launch",
            "name": "Release Tasks",
            "program": "${workspaceFolder}/.build/release/Tasks.app/Contents/MacOS/Tasks",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Bundle Release App"
        }
    ]
}
